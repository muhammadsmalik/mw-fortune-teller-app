# ===========================================
# MW Fortune Teller App - Environment Variables
# ===========================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Ask the project owner for production keys — never commit real values.
#
# Variable names below match what the code reads via process.env.*

# -------------------------------------------
# AI / LLM
# -------------------------------------------

# Google Gemini (primary LLM)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash-preview-04-17
# Model for match reason + talking points (uses the @google/genai SDK)
GEMINI_MATCH_MODEL=gemini-3.1-flash-lite
# Model for the grounded 5-dimension business scorer (Google-Search grounded,
# uses the @google/genai SDK). Read by lib/business-scores.mjs.
GEMINI_SCORE_MODEL=gemini-2.5-flash
# AI Studio key the business scorer falls back to when Vertex creds below are
# unset (it tries GOOGLE_GENERATIVE_AI_API_KEY, then GEMINI_API_KEY).
GOOGLE_GENERATIVE_AI_API_KEY=
# Both grounded paths — match reasons AND the business scorer — prefer Vertex AI
# when these are set (far higher quota than the AI Studio free tier's 15 rpm);
# otherwise they fall back to an API key.
GCP_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_LOCATION=global

# OpenAI (fallback LLM + TTS narration + DALL-E avatars)
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4.1-mini-2025-04-14

# LLM provider selection. Options: GEMINI, OPENAI
LLM_PROVIDER=GEMINI

# Set false to disable Gemini -> OpenAI fallback on error
ENABLE_LLM_FALLBACK=true

# Force Gemini to throw (used to test the fallback path). Leave false in prod.
DEBUG_FORCE_GEMINI_ERROR=false

# -------------------------------------------
# External APIs
# -------------------------------------------

# EnrichLayer (LinkedIn profile + company data) - formerly Proxycurl
ENRICHLAYER_API_KEY=

# Deepgram (speech-to-text for manual flow voice input)
DEEPGRAM_API_KEY=

# Resend (transactional email for fortune delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=agentwalli@movingwalls.com

# Internal MW staff CC'd on every concierge email (comma-separated).
# Suppressed when EMAIL_TEST_MODE=true.
CONCIERGE_CC_EMAILS=

# Public URL of the image used as the email footer
EMAIL_FOOTER_URL=https://i.imgur.com/QROe0T6.jpeg

# NOTE: the "Book a Demo" link in the businessInsight email is now HARD-CODED
# to https://www.movingwalls.com/contact in app/api/send-email/route.js.
# NEXT_PUBLIC_DEMO_URL is no longer read — kept here only as documentation.

# Absolute site origin for server-to-server calls. The business-insight route
# calls /api/send-email by absolute URL from inside after(); set this to the
# canonical deployment URL in prod, or http://localhost:3000 locally. Falls back
# to the incoming request's origin if unset.
NEXT_PUBLIC_SITE_URL=

# Email test mode (booth testing). When EMAIL_TEST_MODE=true, EVERY outbound email
# is rerouted to the comma-separated EMAIL_TEST_RECIPIENTS instead of the real
# attendee/DRI, and the subject is prefixed with [TEST->original-recipient].
# Server-only guardrail — keep false for the live event.
EMAIL_TEST_MODE=false
EMAIL_TEST_RECIPIENTS=test1@example.com,test2@example.com

# Marketing DRI who handles concierge intro requests (read by app/concierge/page.js).
# Falls back to NEXT_PUBLIC_SALES_REP_EMAIL, then atlas1000x@gmail.com, if unset.
NEXT_PUBLIC_CONCIERGE_DRI_EMAIL=

# Legacy internal address for the WOO booth "concierge requested" alert.
# Kept as a fallback for NEXT_PUBLIC_CONCIERGE_DRI_EMAIL.
NEXT_PUBLIC_SALES_REP_EMAIL=

# -------------------------------------------
# Google Sheets (lead capture)
# -------------------------------------------
# Service account creds with edit access to the target sheet.
# Generate from: Google Cloud Console -> IAM & Admin -> Service Accounts.
# The private key must be wrapped in quotes with \n preserved for newlines.

GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=

# -------------------------------------------
# Debug
# -------------------------------------------

# When true, surfaces debug UI (e.g. force-provider buttons). Public to client.
NEXT_PUBLIC_DEBUG=false

# -------------------------------------------
# POC scripts (scripts/poc-*.mjs)
# -------------------------------------------
# Only needed if running the WOO Forum POC scripts. Falls back to GEMINI_API_KEY
# for auth; these vars just control which Gemini model each POC uses.

POC_MODEL=gemini-2.5-flash
POC_NARRATIVE_MODEL=gemini-2.5-flash
POC_TWIN_MODEL=gemini-2.5-flash
